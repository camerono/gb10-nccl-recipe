# nccl env vars that get you ~24 gbps allreduce on a pair of gb10 over single qsfp56.
# pass to docker via --env-file nccl.env (or source into your launcher).
#
# the values below assume you cabled port f1 (second port on the cx-7). if you
# cabled port f0 instead, swap f1 → f0 in every line below. check ibdev2netdev
# first so you don't kerfuffle the whole bench, eh.

NCCL_DEBUG=INFO
NCCL_SOCKET_IFNAME=enp1s0f1np1,enP2p1s0f1np1
NCCL_IB_HCA=rocep1s0f1,roceP2p1s0f1
NCCL_IB_MERGE_NICS=1
NCCL_NET_PLUGIN=none
NCCL_IB_ROCE_VERSION_NUM=2
NCCL_IB_QPS_PER_CONNECTION=8
NCCL_IB_SPLIT_DATA_ON_QPS=1
NCCL_MIN_NCHANNELS=32
NCCL_IB_PCI_RELAXED_ORDERING=1
